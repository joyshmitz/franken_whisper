{
  "name": "noisy_overlap_cross_engine",
  "tags": ["noisy_environment", "multi_speaker_overlap", "bridge"],
  "tolerance": {
    "timestamp_tolerance_sec": 0.1,
    "require_text_exact": false,
    "require_speaker_exact": false
  },
  "expected": [
    {
      "start_sec": 0.0,
      "end_sec": 3.5,
      "text": "The atmosphere is extremely loud and crowded.",
      "speaker": "S0",
      "confidence": 0.8
    },
    {
      "start_sec": 2.0,
      "end_sec": 5.0,
      "text": "I can barely hear what you are saying over the music.",
      "speaker": "S1",
      "confidence": 0.7
    }
  ],
  "observed": [
    {
      "start_sec": 0.05,
      "end_sec": 3.55,
      "text": "The atmosphere is extremely loud and crowded.",
      "speaker": "S0",
      "confidence": 0.85
    },
    {
      "start_sec": 2.1,
      "end_sec": 5.1,
      "text": "I can barely hear what you are saying over the music.",
      "speaker": "S1",
      "confidence": 0.75
    }
  ],
  "expect_within_tolerance": true,
  "expected_timestamp_violations": 0,
  "expected_text_mismatches": 0,
  "engines": [
    {
      "engine": "whisper_cpp_bridge_noisy_overlap",
      "format": "json",
      "artifact": "tests/fixtures/golden/whisper_cpp_overlap_output.json",
      "expect_within_tolerance": true
    },
    {
      "engine": "whisper_cpp_native_noisy_overlap",
      "format": "json",
      "artifact": "tests/fixtures/golden/whisper_cpp_overlap_native_output.json",
      "expect_within_tolerance": true
    },
    {
      "engine": "insanely_fast_bridge_noisy_overlap",
      "format": "json",
      "artifact": "tests/fixtures/golden/insanely_fast_overlap_output.json",
      "expect_within_tolerance": true
    },
    {
      "engine": "insanely_fast_native_noisy_overlap",
      "format": "json",
      "artifact": "tests/fixtures/golden/insanely_fast_overlap_native_output.json",
      "expect_within_tolerance": true
    },
    {
      "engine": "whisper_diarization_bridge_noisy_overlap",
      "format": "diarization_srt",
      "artifact": "tests/fixtures/golden/diarization_overlap_output.srt",
      "expect_within_tolerance": true
    },
    {
      "engine": "whisper_diarization_native_noisy_overlap",
      "format": "diarization_srt",
      "artifact": "tests/fixtures/golden/diarization_overlap_native_output.srt",
      "expect_within_tolerance": true
    }
  ]
}
