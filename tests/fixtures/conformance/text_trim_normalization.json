{
  "name": "text_trim_normalization",
  "tolerance": {
    "timestamp_tolerance_sec": 0.05,
    "require_text_exact": true,
    "require_speaker_exact": false
  },
  "expected": [
    {
      "start_sec": 0.0,
      "end_sec": 1.0,
      "text": "Trim me",
      "speaker": null,
      "confidence": 0.9
    },
    {
      "start_sec": 1.0,
      "end_sec": 2.0,
      "text": "Second segment",
      "speaker": null,
      "confidence": 0.9
    }
  ],
  "observed": [
    {
      "start_sec": 0.0,
      "end_sec": 1.0,
      "text": "  Trim me  ",
      "speaker": null,
      "confidence": 0.85
    },
    {
      "start_sec": 1.0,
      "end_sec": 2.0,
      "text": "Second segment   ",
      "speaker": null,
      "confidence": 0.88
    }
  ],
  "expect_within_tolerance": true,
  "expected_timestamp_violations": 0,
  "expected_text_mismatches": 0,
  "expected_speaker_mismatches": 0
}
