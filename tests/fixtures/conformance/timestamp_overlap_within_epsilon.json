{
  "name": "timestamp_overlap_within_epsilon",
  "tolerance": {
    "timestamp_tolerance_sec": 0.05,
    "require_text_exact": true,
    "require_speaker_exact": false
  },
  "expected": [
    {
      "start_sec": 0.0,
      "end_sec": 1.0,
      "text": "First.",
      "speaker": null,
      "confidence": null
    },
    {
      "start_sec": 0.9999999,
      "end_sec": 2.0,
      "text": "Second.",
      "speaker": null,
      "confidence": null
    }
  ],
  "observed": [
    {
      "start_sec": 0.0,
      "end_sec": 1.0,
      "text": "First.",
      "speaker": null,
      "confidence": null
    },
    {
      "start_sec": 0.9999999,
      "end_sec": 2.0,
      "text": "Second.",
      "speaker": null,
      "confidence": null
    }
  ],
  "expect_within_tolerance": true,
  "expected_timestamp_violations": 0,
  "expected_text_mismatches": 0,
  "expected_speaker_mismatches": 0
}
