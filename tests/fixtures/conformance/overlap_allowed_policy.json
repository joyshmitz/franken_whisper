      "start_sec": 0.0,
      "end_sec": 2.0,
      "text": "first segment",
      "speaker": null,
      "confidence": 0.9
    },
    {
      "start_sec": 1.5,
      "end_sec": 3.0,
      "text": "overlapping segment",
      "speaker": null,
