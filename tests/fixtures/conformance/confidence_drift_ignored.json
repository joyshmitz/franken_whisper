{
  "name": "confidence_drift_ignored",
  "tolerance": {
    "timestamp_tolerance_sec": 0.05,
    "require_text_exact": true,
    "require_speaker_exact": false
  },
  "expected": [
    {
      "start_sec": 0.0,
      "end_sec": 1.0,
      "text": "hello",
      "speaker": null,
      "confidence": 0.95
    },
    {
      "start_sec": 1.0,
      "end_sec": 2.0,
      "text": "world",
      "speaker": null,
      "confidence": 0.90
    }
  ],
  "observed": [
    {
      "start_sec": 0.01,
      "end_sec": 1.0,
      "text": "hello",
      "speaker": null,
      "confidence": 0.10
    },
    {
      "start_sec": 1.0,
      "end_sec": 2.02,
      "text": "world",
      "speaker": null,
      "confidence": null
    }
  ],
  "expect_within_tolerance": true,
  "expected_timestamp_violations": 0,
  "expected_text_mismatches": 0,
  "expected_speaker_mismatches": 0
}
