{
  "name": "timestamp_zero_tolerance_rejects_drift",
  "tolerance": {
    "timestamp_tolerance_sec": 0.0,
    "require_text_exact": true,
    "require_speaker_exact": false
  },
  "expected": [
    {
      "start_sec": 1.0,
      "end_sec": 2.0,
      "text": "strict timing",
      "speaker": null,
      "confidence": 0.90
    }
  ],
  "observed": [
    {
      "start_sec": 1.001,
      "end_sec": 2.0,
      "text": "strict timing",
      "speaker": null,
      "confidence": 0.89
    }
  ],
  "expect_within_tolerance": false,
  "expected_timestamp_violations": 1,
  "expected_text_mismatches": 0,
  "expected_speaker_mismatches": 0
}
